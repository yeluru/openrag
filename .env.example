# OpenRAG backend — copy to .env and adjust

# App
DEBUG=false
LOG_JSON=false
API_PREFIX=/api/v1
SERVICE_API_KEY=
CORS_ORIGINS=http://localhost:3000

# PostgreSQL
# Render.com / managed Postgres: set DATABASE_URL to the provider URL (postgres:// or postgresql://).
# When DATABASE_URL is set, POSTGRES_* below are ignored.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
#
# Local (no DATABASE_URL): async URL is built from these.
# With docker-compose in this repo, use port 5433 (see docker-compose.yml).
POSTGRES_USER=openrag
POSTGRES_PASSWORD=openrag
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=openrag

# Uploads
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=100

# PDF OCR (scanned pages) — requires Tesseract-OCR installed (e.g. brew install tesseract)
PDF_OCR_ENABLED=true
PDF_OCR_LANGUAGE=eng
PDF_OCR_DPI=200
# PDF_OCR_TESSDATA=   # optional: path to tessdata parent dir

# Embeddings (openai | mock)
EMBEDDING_PROVIDER=mock
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=64

# LLM (openai | mock)
LLM_PROVIDER=mock
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Retrieval
RETRIEVAL_DEFAULT_TOP_K=8
# With EMBEDDING_PROVIDER=mock, scores are not semantic—use openai for real similarity or lower this (e.g. 0.05) for local dev only
RETRIEVAL_MIN_SCORE_COSINE=0.25
RETRIEVAL_DEDUPE_OVERLAP_RATIO=0.85

# Dev: attach raw retrieval debug to responses
INCLUDE_RETRIEVAL_DEBUG=false
