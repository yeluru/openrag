{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif",
    "fontSize": "15px",
    "primaryColor": "#E8EAF6",
    "primaryTextColor": "#1a237e",
    "primaryBorderColor": "#3949AB",
    "lineColor": "#546E7A",
    "secondaryColor": "#E3F2FD",
    "tertiaryColor": "#ffffff",
    "noteBkgColor": "#FFF8E1",
    "noteTextColor": "#333333"
  },
  "flowchart": {
    "curve": "basis",
    "padding": 12,
    "nodeSpacing": 50,
    "rankSpacing": 55
  },
  "sequence": {
    "actorMargin": 60,
    "boxMargin": 8,
    "boxTextMargin": 6,
    "noteMargin": 8,
    "messageMargin": 40
  }
}
