{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
    "fontSize": "17px",
    "primaryColor": "#E8EAF6",
    "primaryTextColor": "#1a237e",
    "primaryBorderColor": "#3949AB",
    "lineColor": "#5c6b7a",
    "secondaryColor": "#E3F2FD",
    "tertiaryColor": "#ffffff",
    "noteBkgColor": "#FFF8E1",
    "noteTextColor": "#333333"
  },
  "flowchart": {
    "curve": "basis",
    "padding": 18,
    "nodeSpacing": 58,
    "rankSpacing": 64,
    "htmlLabels": true
  },
  "sequence": {
    "actorMargin": 60,
    "boxMargin": 8,
    "boxTextMargin": 6,
    "noteMargin": 8,
    "messageMargin": 40
  }
}
