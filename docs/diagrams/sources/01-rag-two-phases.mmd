flowchart TB
  classDef client fill:#E3F2FD,stroke:#1565C0,stroke-width:2px
  classDef domain fill:#FFF3E0,stroke:#EF6C00,stroke-width:2px
  classDef data fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px
  classDef ext fill:#ECEFF1,stroke:#546E7A,stroke-width:2px,stroke-dasharray: 5 5

  subgraph T1["Phase 1 — Index build upload and background jobs"]
    direction TB
    U["Your documents"]:::client --> CH["Chunk + structure"]:::domain
    CH --> EM["Embedding model"]:::ext
    EM --> VS[("PostgreSQL + pgvector")]:::data
  end

  subgraph T2["Phase 2 — Answer per question"]
    direction TB
    Q["User question"]:::client --> QE["Embed question"]:::ext
    QE --> SR["Similarity search"]:::domain
    SR --> VS
    VS --> CTX["Top passages + prompt"]:::domain
    CTX --> LLM["LLM"]:::ext
    LLM --> OUT["Answer + citations"]:::client
  end
