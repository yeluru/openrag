flowchart TB
  classDef client fill:#E3F2FD,stroke:#1565C0,stroke-width:2px
  classDef app fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px
  classDef domain fill:#FFF3E0,stroke:#EF6C00,stroke-width:2px
  classDef data fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px
  classDef ext fill:#ECEFF1,stroke:#546E7A,stroke-width:2px,stroke-dasharray: 5 5

  subgraph T1["RAG query path — grounded answer"]
    direction TB
    ASK["POST /chat/ask + scope"]:::app --> QEMB["Embed question"]:::ext
    QEMB --> SR["pgvector cosine top-K"]:::domain
    SR --> VS[("PostgreSQL + pgvector")]:::data
    VS --> POST["Dedupe + min score"]:::domain
    POST --> PROMPT["Build grounded prompt"]:::domain
    PROMPT --> LLM["Chat completion API"]:::ext
    LLM --> RESP["Answer + citations"]:::client
  end
